# MeiMart API 环境变量示例
# 复制为 .env 并填实际值（.env 已 gitignore）

# Database (PostgreSQL 16 + PostGIS 3.4)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DB?schema=public"

# JWT（≥ 32 字符，生产用 openssl rand -hex 32 生成）
JWT_ACCESS_SECRET="change-me-at-least-32-characters-long"
JWT_REFRESH_SECRET="change-me-too-at-least-32-characters-long"

# Redis
REDIS_URL="redis://HOST:6379"

# Server
PORT=3000
NODE_ENV=development

# SMS stub（W6 切东帝汶本地 Timor Telecom/Telkomcel）
SMS_STUB_CODE="123456"

# 邮件（dev MailHog / prod SendGrid）
SMTP_HOST="localhost"
SMTP_PORT=1025

# 对象存储（dev MinIO / prod 阿里云 OSS）
OSS_ENDPOINT="http://localhost:9000"
OSS_ACCESS_KEY="minioadmin"
OSS_SECRET_KEY="minioadmin"
OSS_BUCKET="meimart"

# 支付策略：mock（dev）/ real（prod，W6 后逐个切真）
PAYMENT_STRATEGY="mock"
